# Public — safe in the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — bypasses RLS, NEVER expose
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Direct postgres URLs (used by supabase CLI / migrations)
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...?pgbouncer=true&connection_limit=1

# Site origin override for auth redirects (optional; falls back to
# request Host)
NEXT_PUBLIC_SITE_URL=https://chat-admin.holylabs.dev

# Embed widget allowlist (comma-separated). Every host that iframes
# /embed/widget or /embed/inbox must be listed here, or verifyEmbedKey
# rejects the request. Include the localhost dev origin for the host
# site while iterating locally.
EMBED_ALLOWED_ORIGINS=https://www.isrshipping.com,https://isrshipping.com,https://greenflagged.xyz,https://www.greenflagged.xyz,http://localhost:3000,http://localhost:3001

# Self-embed key used by /support visitor widget
NEXT_PUBLIC_TINYCHAT_SUPPORT_KEY=pk_live_REPLACE_ME

# Local MCP — Supabase personal access token (not committed)
SUPABASE_ACCESS_TOKEN=sbp_...

# Revolut Merchant API (round 3, prompt 7)
# Get a secret API key + webhook secret from developer.revolut.com.
REVOLUT_SECRET_KEY=
REVOLUT_WEBHOOK_SECRET=
REVOLUT_ENVIRONMENT=sandbox

# Vercel Cron (round 3, prompt 9)
# Used to authenticate the /api/cron/execute-deletions cron handler.
# Vercel auto-injects this in production; set it locally to test.
CRON_SECRET=
